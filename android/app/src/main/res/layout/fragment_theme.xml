<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:paddingBottom="@dimen/spacing_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_xs"
            android:text="@string/settings_theme"
            android:textAllCaps="true"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Hubble.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_description"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    android:layout_marginTop="@dimen/spacing_md">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/previewLight"
                        style="@style/Widget.Hubble.CardView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        app:cardBackgroundColor="#F6F7F9"
                        app:cardCornerRadius="22dp"
                        app:strokeColor="#D4D7DC"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <View
                                android:layout_width="84dp"
                                android:layout_height="8dp"
                                android:layout_marginBottom="@dimen/spacing_md"
                                android:background="@drawable/bg_theme_preview_light" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:paddingBottom="@dimen/spacing_md">

                                    <View
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:background="@drawable/bg_theme_preview_light" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:paddingStart="@dimen/spacing_md">

                                        <View
                                            android:layout_width="120dp"
                                            android:layout_height="10dp"
                                            android:background="@drawable/bg_theme_preview_light" />

                                        <View
                                            android:layout_width="160dp"
                                            android:layout_height="8dp"
                                            android:layout_marginTop="8dp"
                                            android:background="@drawable/bg_theme_preview_light" />

                                    </LinearLayout>

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:paddingBottom="@dimen/spacing_md">

                                    <View
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:background="@drawable/bg_theme_preview_light" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:paddingStart="@dimen/spacing_md">

                                        <View
                                            android:layout_width="140dp"
                                            android:layout_height="10dp"
                                            android:background="@drawable/bg_theme_preview_light" />

                                        <View
                                            android:layout_width="150dp"
                                            android:layout_height="8dp"
                                            android:layout_marginTop="8dp"
                                            android:background="@drawable/bg_theme_preview_light" />

                                    </LinearLayout>

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical">

                                    <View
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:background="@drawable/bg_theme_preview_light" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:paddingStart="@dimen/spacing_md">

                                        <View
                                            android:layout_width="110dp"
                                            android:layout_height="10dp"
                                            android:background="@drawable/bg_theme_preview_light" />

                                        <View
                                            android:layout_width="170dp"
                                            android:layout_height="8dp"
                                            android:layout_marginTop="8dp"
                                            android:background="@drawable/bg_theme_preview_light" />

                                    </LinearLayout>

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/previewDark"
                        style="@style/Widget.Hubble.CardView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:cardCornerRadius="22dp"
                        app:strokeColor="?attr/colorOutline"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <View
                                android:layout_width="92dp"
                                android:layout_height="8dp"
                                android:layout_marginBottom="@dimen/spacing_md"
                                android:background="@drawable/bg_theme_preview_dark" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:paddingBottom="@dimen/spacing_md">

                                    <View
                                        android:layout_width="42dp"
                                        android:layout_height="42dp"
                                        android:background="@drawable/bg_theme_preview_dark" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:paddingStart="@dimen/spacing_md">

                                        <View
                                            android:layout_width="120dp"
                                            android:layout_height="10dp"
                                            android:background="@drawable/bg_theme_preview_dark" />

                                        <View
                                            android:layout_width="170dp"
                                            android:layout_height="8dp"
                                            android:layout_marginTop="8dp"
                                            android:background="@drawable/bg_theme_preview_dark" />

                                    </LinearLayout>

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:paddingBottom="@dimen/spacing_md">

                                    <View
                                        android:layout_width="42dp"
                                        android:layout_height="42dp"
                                        android:background="@drawable/bg_theme_preview_dark" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:paddingStart="@dimen/spacing_md">

                                        <View
                                            android:layout_width="150dp"
                                            android:layout_height="10dp"
                                            android:background="@drawable/bg_theme_preview_dark" />

                                        <View
                                            android:layout_width="160dp"
                                            android:layout_height="8dp"
                                            android:layout_marginTop="8dp"
                                            android:background="@drawable/bg_theme_preview_dark" />

                                    </LinearLayout>

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical">

                                    <View
                                        android:layout_width="42dp"
                                        android:layout_height="42dp"
                                        android:background="@drawable/bg_theme_preview_dark" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:paddingStart="@dimen/spacing_md">

                                        <View
                                            android:layout_width="110dp"
                                            android:layout_height="10dp"
                                            android:background="@drawable/bg_theme_preview_dark" />

                                        <View
                                            android:layout_width="150dp"
                                            android:layout_height="8dp"
                                            android:layout_marginTop="8dp"
                                            android:background="@drawable/bg_theme_preview_dark" />

                                    </LinearLayout>

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/optionSystem"
                            style="@style/Widget.Hubble.CardView"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="?attr/colorSurfaceVariant"
                            app:cardCornerRadius="12dp"
                            app:strokeColor="?attr/colorOutline"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/iconSystemSelected"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_selection_unchecked" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/textSystemTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/theme_system"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <Space
                        android:layout_width="@dimen/spacing_lg"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/optionLight"
                            style="@style/Widget.Hubble.CardView"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:strokeColor="?attr/colorOutline"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/iconLightSelected"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_selection_unchecked" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/textLightTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/theme_light"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <Space
                        android:layout_width="@dimen/spacing_lg"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/optionDark"
                            style="@style/Widget.Hubble.CardView"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#000000"
                            app:cardCornerRadius="12dp"
                            app:strokeColor="?attr/colorOutline"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/iconDarkSelected"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_selection_unchecked" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/textDarkTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/theme_dark"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
