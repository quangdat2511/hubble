<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:tint="@color/color_text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/otp_title"
        android:textColor="@color/color_text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <TextView
        android:id="@+id/tvOtpSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/otp_subtitle"
        android:textColor="@color/color_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <LinearLayout
        android:id="@+id/llOtpInputs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOtpSubtitle">

        <EditText
            android:id="@+id/etOtp1"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_otp_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/color_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/etOtp2"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_otp_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/color_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/etOtp3"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_otp_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/color_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <View
            android:layout_width="12dp"
            android:layout_height="2dp"
            android:layout_margin="4dp"
            android:background="@color/color_text_hint" />

        <EditText
            android:id="@+id/etOtp4"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_otp_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/color_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/etOtp5"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_otp_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/color_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:cursorVisible="false" />

        <EditText
            android:id="@+id/etOtp6"
            android:layout_width="44dp"
            android:layout_height="52dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_otp_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/color_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:cursorVisible="false" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/color_primary"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llOtpInputs" />

    <Button
        android:id="@+id/btnVerify"
        style="@style/Widget.Hubble.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:text="@string/otp_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnVerify">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/otp_resend_prefix"
            android:textColor="@color/color_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/otp_resend_active"
            android:textColor="@color/color_link"
            android:textSize="14sp"
            android:enabled="false"
            android:alpha="0.5" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
