<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="16dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@android:color/darker_gray" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipReactionOk"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="👌"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/chipReactionLike"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="👍"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/chipReactionTwo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="2️⃣"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/chipReactionHeart"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="❤️"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/chipReactionThree"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="3️⃣"
                android:textSize="24sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionEdit"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="@string/edit_message"
            android:textAllCaps="false"
            app:icon="@drawable/ic_edit"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionReply"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="@string/reply"
            android:textAllCaps="false"
            app:icon="@drawable/ic_reply"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionCopyText"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="@string/copy_text"
            android:textAllCaps="false"
            app:icon="@drawable/ic_copy"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionForward"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="@string/forward"
            android:textAllCaps="false"
            app:icon="@drawable/ic_forward"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionPin"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="@string/pin_message"
            android:textAllCaps="false"
            app:icon="@drawable/ic_pin"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionUnsend"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="@string/delete_message"
            android:textAllCaps="false"
            android:textColor="?attr/colorError"
            app:icon="@drawable/ic_delete"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="?attr/colorError" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
