<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="?attr/colorSurface"
        app:contentInsetStart="0dp"
        app:contentInsetStartWithNavigation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/colorOnSurface"
        app:title="" />

    <LinearLayout
        android:id="@+id/headerInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="52dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toStartOf="@+id/headerActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/toolbar"
        app:layout_constraintTop_toTopOf="@id/toolbar">

        <TextView
            android:id="@+id/tvHeaderHashMark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="#"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:importantForAccessibility="no" />

        <FrameLayout
            android:id="@+id/headerAvatarContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivHeaderAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_user_avatar"
                android:src="@mipmap/ic_launcher_round"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <View
                android:id="@+id/viewHeaderStatusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-1dp"
                android:layout_marginBottom="-1dp"
                android:background="@drawable/bg_dm_header_status_dot"
                android:visibility="gone" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvHeaderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivHeaderChevron"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvHeaderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/headerActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="10dp"
        app:layout_constraintBottom_toBottomOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/toolbar">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHeaderSearch"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:padding="0dp"
            android:visibility="gone"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:contentDescription="@string/cd_search"
            app:icon="@drawable/ic_search"
            app:iconTint="?attr/colorOnSurfaceVariant"
            app:backgroundTint="?attr/colorSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCall"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:padding="0dp"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:contentDescription="@string/cd_call"
            app:icon="@drawable/ic_call"
            app:iconTint="?attr/colorOnSurfaceVariant"
            app:backgroundTint="?attr/colorSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVideo"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:padding="0dp"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/cd_video"
            app:icon="@drawable/ic_video"
            app:iconTint="?attr/colorOnSurfaceVariant"
            app:backgroundTint="?attr/colorSurfaceVariant" />

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- layoutDmProfileIntro is kept for binding compatibility but always hidden;
         profile intro is now the first item inside the RecyclerView. -->
    <LinearLayout
        android:id="@+id/layoutDmProfileIntro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="?android:attr/colorBackground"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfileIntroAvatar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:contentDescription="@string/cd_user_avatar"
            android:src="@mipmap/ic_launcher_round"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <TextView
            android:id="@+id/tvProfileIntroDisplayName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceHeadlineLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProfileIntroUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvProfileIntroDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/copyBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_copy"
                app:tint="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvCopyBannerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/copied_message_text"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        app:layout_constraintBottom_toTopOf="@id/typingIndicatorBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <!-- Typing indicator: visible when peer is typing -->
    <LinearLayout
        android:id="@+id/typingIndicatorBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/editBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/typingDot1"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/bg_typing_dot" />

        <View
            android:id="@+id/typingDot2"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_typing_dot" />

        <View
            android:id="@+id/typingDot3"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_typing_dot" />

        <TextView
            android:id="@+id/tvTypingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/editBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/replyBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelEdit"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/cd_cancel_edit"
            app:icon="@drawable/ic_close"
            app:iconTint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvEditingLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/editing_message"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/replyBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/suggestionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="10dp"
            android:background="?attr/colorPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReplySender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReplyContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelReply"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/cd_reply_cancel"
            app:icon="@drawable/ic_close"
            app:iconTint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/suggestionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/attachmentPreviewBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvContextTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="italic"
                android:textColor="?attr/colorPrimary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgSuggestions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true" />

        </LinearLayout>
    </HorizontalScrollView>

    <HorizontalScrollView
        android:id="@+id/attachmentPreviewBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_sm"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/composerBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/llAttachmentPreviews"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/composerBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        app:layout_constraintBottom_toTopOf="@id/emojiPickerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Shown when field is empty; hidden while typing -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAttach"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/cd_add_server"
            app:icon="@drawable/ic_add"
            app:iconTint="?attr/colorOnSurfaceVariant" />

        <!-- Shown while typing; collapses back to attachment panel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCollapse"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:contentDescription="Mở rộng"
            app:icon="@drawable/ic_chevron_right"
            app:iconTint="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilComposer"
            style="@style/Widget.Material3.TextInputLayout.FilledBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_weight="1"
            app:hintEnabled="false"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusTopStart="24dp"
            app:boxBackgroundColor="@color/color_surface_elevated"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:endIconMode="none"
            app:startIconDrawable="@null">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etComposer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/dm_message_hint_static"
                android:textColorHint="@color/color_text_hint"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:gravity="center_vertical|start"
                android:inputType="textMultiLine|textCapSentences|textAutoCorrect"
                android:imeOptions="flagNoEnterAction"
                android:maxLines="4"
                android:minLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmoji"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/cd_emoji_picker"
            app:icon="@drawable/ic_emoji"
            app:iconTint="?attr/colorOnSurfaceVariant" />

        <!-- Microphone: visible when field is empty -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoice"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Ghi âm"
            app:icon="@android:drawable/ic_btn_speak_now"
            app:iconTint="?attr/colorOnSurfaceVariant" />

        <!-- Send: visible when field has text -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:contentDescription="@string/dm_send"
            app:icon="@drawable/ic_send"
            app:iconTint="@color/white" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/emojiPickerContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.example.hubble.view.emoji.EmojiPickerView
            android:id="@+id/emojiPickerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>