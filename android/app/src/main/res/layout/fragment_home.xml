<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="@dimen/sidebar_width"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:orientation="vertical">

        <!-- DM button with active-indicator pill -->
        <FrameLayout
            android:layout_width="@dimen/sidebar_width"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/viewDmActiveIndicator"
                android:layout_width="@dimen/server_active_indicator_width"
                android:layout_height="@dimen/server_active_indicator_height"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/bg_server_active_indicator"
                android:visibility="gone" />

            <View
                android:id="@+id/viewDmUnreadPill"
                android:layout_width="@dimen/server_active_indicator_width"
                android:layout_height="@dimen/server_unread_indicator_height"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/bg_server_unread_pill"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_margin="@dimen/spacing_sm">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDmView"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/dm_title"
                    app:icon="@drawable/ic_message"
                    app:iconTint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/tvDmSidebarBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="2dp"
                    android:layout_marginBottom="2dp"
                    android:background="@drawable/bg_unread_badge_red"
                    android:gravity="center"
                    android:minWidth="18dp"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="?attr/colorOutline" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvServers"
            android:layout_width="@dimen/sidebar_width"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="?attr/colorOutline" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddServer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="@dimen/spacing_sm"
            android:contentDescription="@string/cd_add_server"
            app:backgroundTint="?attr/colorSurfaceVariant"
            app:fabSize="mini"
            app:srcCompat="@drawable/ic_add"
            app:tint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="?attr/colorOutline" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- DM Panel -->
        <LinearLayout
            android:id="@+id/layout_dm_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md"
            android:visibility="visible">

            <TextView
                android:id="@+id/tvDmTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dm_title"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSearch"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/cd_search"
                    app:icon="@drawable/ic_search"
                    app:iconTint="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddFriend"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:text="@string/dm_add_friend"
                    app:icon="@drawable/ic_person"
                    app:iconTint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="@dimen/spacing_sm" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvConversations"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="@dimen/spacing_md" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/spacing_sm">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabNewDm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/dm_new_message"
                    app:backgroundTint="?attr/colorPrimary"
                    app:elevation="8dp"
                    app:fabCustomSize="64dp"
                    app:maxImageSize="30dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Avatar"
                    app:srcCompat="@drawable/ic_person"
                    app:tint="@color/white"
                    app:useCompatPadding="false" />

                <FrameLayout
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="9dp"
                    android:background="@drawable/bg_dm_fab_badge"
                    android:clickable="false"
                    android:focusable="false"
                    android:importantForAccessibility="no">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="3dp"
                        android:src="@drawable/ic_dm_plus" />
                </FrameLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- Server Channels Panel -->
        <LinearLayout
            android:id="@+id/layout_server_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md"
            android:visibility="gone">

            <!-- Server header row with chevron -->
            <LinearLayout
                android:id="@+id/layoutServerHeader"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvServerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </LinearLayout>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvServerChannels"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="@dimen/spacing_md" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
