<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="2dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:rippleColor="?attr/colorControlHighlight"
    style="@style/Widget.Hubble.CardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Avatar with status dot -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="@dimen/spacing_md">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                app:shapeAppearance="@style/ShapeAppearance.App.Avatar" />

            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Online status dot -->
            <View
                android:id="@+id/viewOnlineStatus"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-1dp"
                android:layout_marginBottom="-1dp"
                android:background="@drawable/bg_server_active_indicator"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Member info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name row with optional owner crown -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <!-- Owner crown badge -->
                <ImageView
                    android:id="@+id/ivOwnerCrown"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_crown"
                    android:visibility="gone"
                    app:tint="@color/color_mention" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvUsernameHandle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />

            <!-- Role chips -->
            <LinearLayout
                android:id="@+id/llRoleChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- Chevron -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_chevron_right"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
