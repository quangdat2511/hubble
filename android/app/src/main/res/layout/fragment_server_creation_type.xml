<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_background"
        app:navigationIcon="@drawable/ic_close"
        app:navigationIconTint="@color/color_text_primary"
        app:title="@string/create_server_title"
        app:titleTextColor="@color/color_text_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:gravity="center"
                android:text="@string/create_server_subtitle"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp" />

            <!-- Create My Own card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCreateOwn"
                style="@style/Widget.Hubble.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/create_server_own"
                            android:textColor="@color/color_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/color_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Templates header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:letterSpacing="0.1"
                android:text="@string/create_server_templates_header"
                android:textColor="@color/color_text_hint"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Template: Gaming -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTemplateGaming"
                style="@style/Widget.Hubble.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:text="🎮"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/create_server_template_gaming"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/color_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Template: School Club -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTemplateSchool"
                style="@style/Widget.Hubble.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:text="🏫"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/create_server_template_school"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/color_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Template: Study Group -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTemplateStudy"
                style="@style/Widget.Hubble.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:text="📚"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/create_server_template_study"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/color_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Template: Friends -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTemplateFriends"
                style="@style/Widget.Hubble.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:text="❤️"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/create_server_template_friends"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/color_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Template: Artists -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTemplateArtists"
                style="@style/Widget.Hubble.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:text="🎨"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/create_server_template_artists"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/color_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Template: Local Community -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTemplateLocal"
                style="@style/Widget.Hubble.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_card"
                        android:gravity="center"
                        android:text="🏘️"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/create_server_template_local"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/color_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
