<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#5000C853" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- Inner solid ring -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="@color/color_success" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
