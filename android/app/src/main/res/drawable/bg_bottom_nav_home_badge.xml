<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- White ring (Discord-style) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/white" />
            <size
                android:width="12dp"
                android:height="12dp" />
        </shape>
    </item>
    <!-- Blue dot -->
    <item
        android:bottom="2dp"
        android:end="2dp"
        android:start="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/discord_nav_home_badge_blue" />
        </shape>
    </item>
</layer-list>
