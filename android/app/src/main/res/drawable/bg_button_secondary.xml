<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_divider" />
            <stroke android:width="1dp" android:color="@color/color_text_hint" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/color_surface_elevated" />
            <stroke android:width="1dp" android:color="@color/color_divider" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
